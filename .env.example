# Required environment variables
DATABASE_URL="postgres://user:pwd@host:port/dbname?schema=public"
SESSION_SECRET="your session secret"

# Optional environment variables
# Initial value for `steamApiKey` rule.
STEAM_API_KEY="the key from https://steamcommunity.com/dev/apikey"
# Initial value for `steamCallbackUrl` rule.
STEAM_CALLBACK_URL="http://your.domain/sign-in/steam/callback"
# Initial value for `app3dViewerKey` rule.
VIEWER_KEY=""
# The CS2 3D viewer embed URL (its `/view` page). Only set this if you are
# self-hosting the viewer; defaults to the public viewer at
# https://3d.cstrike.app/view.
VIEWER_EMBED_URL=""
# Base URL the 3D viewer loads its economy assets from (weapon models, textures,
# sticker masks, model-data). Only set this if you serve a self-hosted mirror of
# the viewer's asset tree; it must be an absolute http(s) URL serving the same
# paths with permissive CORS. Defaults to the viewer's public CDN.
VIEWER_ASSETS_BASE_URL=""
# Cloudflare Analytics token
CLOUDFLARE_ANALYTICS_TOKEN="your cloudflare web analytics token"
# Only change this if you're handling assets hosting on your own.
# You may remove it if you're using our default CDN.
# This will NOT affect items that uses Valve's CDN (mostly stickers and items from CS:GO).
ASSETS_BASE_URL=""